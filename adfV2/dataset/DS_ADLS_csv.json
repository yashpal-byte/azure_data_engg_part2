{
	"name": "DS_ADLS_csv",
	"properties": {
		"linkedServiceName": {
			"referenceName": "LK_adlspart2V2",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"table_name": {
				"type": "string"
			},
			"table_catalog": {
				"type": "string"
			}
		},
		"annotations": [],
		"type": "DelimitedText",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@{dataset().table_name}/@{formatDateTime(utcNow(),'yyyy')}/@{formatDateTime(utcNow(),'MM')}/@{formatDateTime(utcNow(),'dd')}",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat('rl-sql-001',dataset().table_catalog)",
					"type": "Expression"
				},
				"fileSystem": "blob"
			},
			"columnDelimiter": ",",
			"escapeChar": "\\",
			"firstRowAsHeader": true,
			"quoteChar": "\""
		},
		"schema": []
	}
}