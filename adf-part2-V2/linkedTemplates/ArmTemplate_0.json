{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-part2-V2"
		},
		"LK_adlspart2V2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LK_adlspart2V2'"
		},
		"LS_DS_mysql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_DS_mysql'"
		},
		"LK_adlspart2V2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlspart2v2.dfs.core.windows.net/"
		},
		"LS_DS_mysql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost"
		},
		"LS_DS_mysql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sakila"
		},
		"LS_DS_mysql_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "root"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/SHIR')]",
			"type": "Microsoft.DataFactory/factories/integrationRuntimes",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "SelfHosted",
				"typeProperties": {}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/LK_adlspart2V2')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('LK_adlspart2V2_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('LK_adlspart2V2_accountKey')]"
					}
				},
				"connectVia": {
					"referenceName": "SHIR",
					"type": "IntegrationRuntimeReference"
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/integrationRuntimes/SHIR')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/LS_DS_mysql')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "MySql",
				"typeProperties": {
					"server": "[parameters('LS_DS_mysql_properties_typeProperties_server')]",
					"port": 3306,
					"database": "[parameters('LS_DS_mysql_properties_typeProperties_database')]",
					"username": "[parameters('LS_DS_mysql_properties_typeProperties_username')]",
					"sslMode": 1,
					"useSystemTrustStore": 0,
					"password": {
						"type": "SecureString",
						"value": "[parameters('LS_DS_mysql_password')]"
					},
					"driverVersion": "v2"
				},
				"connectVia": {
					"referenceName": "SHIR",
					"type": "IntegrationRuntimeReference"
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/integrationRuntimes/SHIR')]"
			]
		}
	]
}