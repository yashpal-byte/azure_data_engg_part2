{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-part2-V2"
		},
		"LK_adlspart2V2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LK_adlspart2V2'"
		},
		"LS_DS_mysql_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_DS_mysql'"
		},
		"LK_adlspart2V2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlspart2v2.dfs.core.windows.net/"
		},
		"LS_DS_mysql_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost"
		},
		"LS_DS_mysql_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sakila"
		},
		"LS_DS_mysql_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "root"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-part2-V2_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LK_adlspart2V2_accountKey": {
						"value": "[parameters('LK_adlspart2V2_accountKey')]"
					},
					"LS_DS_mysql_password": {
						"value": "[parameters('LS_DS_mysql_password')]"
					},
					"LK_adlspart2V2_properties_typeProperties_url": {
						"value": "[parameters('LK_adlspart2V2_properties_typeProperties_url')]"
					},
					"LS_DS_mysql_properties_typeProperties_server": {
						"value": "[parameters('LS_DS_mysql_properties_typeProperties_server')]"
					},
					"LS_DS_mysql_properties_typeProperties_database": {
						"value": "[parameters('LS_DS_mysql_properties_typeProperties_database')]"
					},
					"LS_DS_mysql_properties_typeProperties_username": {
						"value": "[parameters('LS_DS_mysql_properties_typeProperties_username')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}